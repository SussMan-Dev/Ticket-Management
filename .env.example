# Copy this file to .env and replace every change_me value.
# Never commit real database credentials or JWT secrets.

NODE_ENV=development
PORT=3000
API_PREFIX=/api/v1
REQUEST_BODY_LIMIT=1mb
TRUST_PROXY=false

# Public URL and local directory used for uploaded profile images.
PUBLIC_BASE_URL=http://localhost:3000
UPLOAD_DIRECTORY=uploads
IMAGE_UPLOAD_MAX_BYTES=5242880

DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=change_me
DB_NAME=electronicfixer
DB_CONNECTION_LIMIT=10

CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Authentication security settings.
BCRYPT_SALT_ROUNDS=12
AUTH_MAX_FAILED_ATTEMPTS=5
AUTH_LOCK_DURATION_MINUTES=15
LOGIN_RATE_LIMIT_WINDOW_MS=900000
LOGIN_RATE_LIMIT_MAX_ATTEMPTS=10

# Use independent random values of at least 32 characters.
JWT_ACCESS_SECRET=replace_with_a_random_access_secret_at_least_32_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=replace_with_a_different_refresh_secret_at_least_32_chars
JWT_REFRESH_EXPIRES_IN=30d
JWT_ISSUER=repair-ticket-system
JWT_AUDIENCE=repair-ticket-client
REFRESH_COOKIE_NAME=repair_refresh_token

# Required only when running npm run seed:admin.
ADMIN_FULL_NAME=change_me
ADMIN_EMAIL=change_me@example.com
ADMIN_PASSWORD=change_me_with_a_strong_password
